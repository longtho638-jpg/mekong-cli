# =============================================================================
# RaaS LICENSE (Premium Features)
# =============================================================================
# Required for premium agents: CTO Auto-Pilot, Opus-gated features
# Get license key from: https://mekong-cli.dev/licensing
RAAS_LICENSE_KEY=your-license-key-here

# =============================================================================
# LLM Provider (any OpenAI-compatible API)
# =============================================================================
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key

# Antigravity Proxy (default: http://localhost:9191)
ANTHROPIC_BASE_URL=http://localhost:9191
ANTHROPIC_MODEL=gemini-3-pro-high

# DashScope (Bailian Coding Plan - free tier)
DASHSCOPE_API_KEY=sk-sp-your-dashscope-key

# Google Gemini (fallback)
GEMINI_API_KEY=your-gemini-api-key

# =============================================================================
# API Gateway (optional - for serving the API)
# =============================================================================
MEKONG_API_TOKEN=your-secure-token
API_PORT=8000

# =============================================================================
# Telegram Bot (Tôm Hùm Autonomous Daemon)
# =============================================================================
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
MEKONG_TELEGRAM_TOKEN=your-telegram-bot-token

# =============================================================================
# POLAR.SH (Payment & Revenue)
# =============================================================================
POLAR_ACCESS_TOKEN=your-polar-access-token
POLAR_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# CLOUDFLARE (Deployment)
# =============================================================================
CLOUDFLARE_API_TOKEN=your-cloudflare-token
CLOUDFLARE_ACCOUNT_ID=your-account-id

# =============================================================================
# Database (optional - defaults to SQLite)
# =============================================================================
# DATABASE_URL=postgresql://user:pass@localhost/mekong

# =============================================================================
# OAuth2 Authentication (Google + GitHub)
# =============================================================================
# Google OAuth2: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth2: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# OAuth2 redirect URI (default: http://localhost:8080/auth/callback)
OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback

# =============================================================================
# JWT / Auth Security
# =============================================================================
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ACCESS_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=30
LICENSE_SECRET=your-license-signing-secret
AUDIT_SIGNING_KEY=your-audit-signing-key
SESSION_MAX_AGE_SECONDS=86400
AUTH_ENVIRONMENT=production
RAAS_JWT_SECRET=your-raas-jwt-secret
RAAS_ENCRYPTION_KEY=your-32-byte-encryption-key
RAAS_KEY_SECRET=your-key-secret
RAAS_CREDENTIALS_FILE=~/.raas/credentials.json

# =============================================================================
# RaaS Gateway / Rate Limiting
# =============================================================================
RAAS_API_URL=https://raas.agencyos.network
RAAS_API_KEY=your-raas-api-key
RAAS_API_TOKEN=your-raas-api-token
RAAS_API_PORT=8000
RAAS_GATEWAY_URL=https://raas.agencyos.network
RAAS_GATEWAY_URL_SECONDARY=
RAAS_GATEWAY_URL_TERTIARY=
RAAS_REQUEST_TIMEOUT=30
RAAS_DEBUG=false
RAAS_LOCAL_TEST=false
RAAS_USE_CERTIFICATE_AUTH=false
RAAS_USE_SECURE_STORAGE=false
DEV_LICENSE_FALLBACK=false
DISABLE_RATE_LIMITING=false

# =============================================================================
# Stripe (secondary billing)
# =============================================================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_WEBHOOK_URL=https://yourdomain.com/webhooks/stripe
STRIPE_PRICE_IDS=price_xxx,price_yyy

# =============================================================================
# Metrics / Monitoring / Webhooks
# =============================================================================
METRICS_API_ENDPOINT=https://metrics.agencyos.network
DASHBOARD_WEBHOOK_SECRET=your-dashboard-webhook-secret
RECONCILIATION_WEBHOOK_URL=https://yourdomain.com/webhooks/reconciliation

# =============================================================================
# Hybrid LLM Router
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-xxx
GOOGLE_API_KEY=AIzaSyxxx
OPENAI_API_KEY=sk-xxx
OLLAMA_URL=http://localhost:11434
GPU_TOTAL_VRAM_GB=8
ALLOW_OPUS_TIERS=premium,enterprise
DEFAULT_TENANT_TIER=starter
LOG_LEVEL=INFO
SENTRY_DSN=
TELEMETRY_ENABLED=true

# =============================================================================
# Mekong Core Config
# =============================================================================
MEKONG_API_KEY=your-mekong-api-key
MEKONG_PROJECT_ID=your-project-id
MEKONG_CHAT_ID=your-telegram-chat-id
TELEGRAM_OPS_CHANNEL_ID=your-ops-channel-id
TELEGRAM_API_TOKEN=your-telegram-api-token
MEKONG_DEV_MODE=false
MEKONG_NO_UPDATE_CHECK=false
MEKONG_NO_USAGE_TRACKING=false
MEMORY_PROVIDER=local

# =============================================================================
# Docker / Kubernetes (optional)
# =============================================================================
DOCKER_IMAGE_NAME=mekong-cli
DOCKER_CONTAINER_NAME=mekong
DEPLOY_TO_K8S=false
K8S_DEPLOYMENT_NAME=mekong-cli
K8S_NAMESPACE=default

# =============================================================================
# Admin
# =============================================================================
ADMIN_EMAIL=admin@yourdomain.com
