# =============================================================================
# Mekong CLI v5.0 — Environment Configuration
# =============================================================================

# LLM Provider (pick one — any OpenAI-compatible endpoint)
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-v1-yourkey
# LLM_MODEL=anthropic/claude-sonnet-4

# Or provider-specific key (auto-detect):
# OPENROUTER_API_KEY=sk-or-v1-...          # 300+ models, $5 free
# DASHSCOPE_API_KEY=sk-...                 # Qwen Coding Plan ~$10/mo
# DEEPSEEK_API_KEY=sk-...                  # DeepSeek cheap
# ANTHROPIC_API_KEY=sk-ant-...             # Claude direct
# OPENAI_API_KEY=sk-...                    # GPT direct
# GOOGLE_API_KEY=AI...                     # Gemini

# Or local LLM (free, offline):
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5-coder

# RaaS (optional — for credit billing)
# POLAR_WEBHOOK_SECRET=whsec_...
# RAAS_LICENSE_KEY=your-license-key

# LiteLLM Proxy (unified LLM gateway — optional)
# LITELLM_MASTER_KEY=sk-mekong-local
# LITELLM_URL=http://localhost:4000
# LITELLM_DB_URL=sqlite:///litellm.db
