# =============================================================================
# RaaS LICENSE (Premium Features)
# =============================================================================
# Required for premium agents: CTO Auto-Pilot, Opus-gated features
# Get license key from: https://mekong-cli.dev/licensing
RAAS_LICENSE_KEY=your-license-key-here

# =============================================================================
# LLM Provider (any OpenAI-compatible API)
# =============================================================================
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key

# Antigravity Proxy (default: http://localhost:9191)
ANTHROPIC_BASE_URL=http://localhost:9191
ANTHROPIC_MODEL=gemini-3-pro-high

# DashScope (Bailian Coding Plan - free tier)
DASHSCOPE_API_KEY=sk-sp-your-dashscope-key

# Google Gemini (fallback)
GEMINI_API_KEY=your-gemini-api-key

# =============================================================================
# API Gateway (optional - for serving the API)
# =============================================================================
MEKONG_API_TOKEN=your-secure-token
API_PORT=8000

# =============================================================================
# Telegram Bot (Tôm Hùm Autonomous Daemon)
# =============================================================================
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
MEKONG_TELEGRAM_TOKEN=your-telegram-bot-token

# =============================================================================
# POLAR.SH (Payment & Revenue)
# =============================================================================
POLAR_ACCESS_TOKEN=your-polar-access-token
POLAR_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# CLOUDFLARE (Deployment)
# =============================================================================
CLOUDFLARE_API_TOKEN=your-cloudflare-token
CLOUDFLARE_ACCOUNT_ID=your-account-id

# =============================================================================
# Database (optional - defaults to SQLite)
# =============================================================================
# DATABASE_URL=postgresql://user:pass@localhost/mekong

# =============================================================================
# OAuth2 Authentication (Google + GitHub)
# =============================================================================
# Google OAuth2: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth2: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# OAuth2 redirect URI (default: http://localhost:8080/auth/callback)
OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback
