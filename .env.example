# AI / LLM Configuration
LLM_BASE_URL=http://localhost:9191
ANTHROPIC_BASE_URL=http://localhost:9191
OPENAI_API_KEY=sk-your-openai-api-key

# API Configuration
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Database (Optional - for advanced features)
DATABASE_URL=postgresql://user:pass@localhost/mekong

# Infrastructure (Engine/Worker)
REDIS_HOST=localhost
REDIS_PORT=6379
SERVICE_TOKEN=your-secure-service-token

# Email (Transactional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# License Generation
LICENSE_SECRET_KEY=your_32_char_secret_key_here

# RaaS API (Robot-as-a-Service)
MEKONG_API_TOKEN=your-secure-api-token
RAAS_JWT_SECRET=your-jwt-signing-secret-256bit

# Telegram Bot (Optional)
MEKONG_TELEGRAM_TOKEN=your-telegram-bot-token

# Supabase (for auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Environment
NODE_ENV=development
PYTHON_ENV=development
