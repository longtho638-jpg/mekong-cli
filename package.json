{
  "name": "mekong-cli",
  "version": "2.1.33",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "description": "RaaS Agency Operating System - Powered by Binh Phap & ClaudeKit DNA",
  "author": "Binh Phap Venture Studio",
  "license": "MIT",
  "homepage": "https://agencyos.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/longtho638-jpg/mekong-cli.git"
  },
  "bugs": {
    "url": "https://github.com/longtho638-jpg/mekong-cli/issues"
  },
  "workspaces": [
    "frontend",
    "packages/*",
    "packages/core/*",
    "packages/integrations/*",
    "packages/business/*",
    "packages/ui/*",
    "packages/tooling/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "cd apps/web && pnpm dev",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload --port 8000",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format"
  },
  "devDependencies": {
    "@types/node": "25.3.2",
    "concurrently": "^8.2.2",
    "turbo": "^2.1.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "sonner": "^2.0.7"
  },
  "pnpm": {
    "overrides": {
      "undici@>=4.5.0 <5.28.5": ">=5.28.5",
      "path-to-regexp@>=4.0.0 <6.3.0": ">=6.3.0",
      "tmp@<=0.2.3": ">=0.2.4",
      "glob@>=11.0.0 <11.1.0": ">=11.1.0",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "undici@<6.23.0": ">=6.23.0",
      "next@>=15.6.0-canary.0 <16.1.5": ">=16.1.5",
      "next@>=16.0.0-beta.0 <16.0.11": ">=16.0.11",
      "fastify@<=5.7.2": ">=5.7.3",
      "fastify@<5.7.2": ">=5.7.2",
      "next@>=16.0.0-beta.0 <16.1.5": ">=16.1.5",
      "undici@<5.29.0": ">=5.29.0",
      "qs@>=6.7.0 <=6.14.1": ">=6.14.2",
      "hono@<4.11.10": ">=4.11.10",
      "ajv@<6.14.0": ">=6.14.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "bn.js@>=5.0.0 <5.2.3": ">=5.2.3",
      "minimatch@<3.1.3": ">=3.1.3",
