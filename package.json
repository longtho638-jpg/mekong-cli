{
  "name": "mekong-cli",
  "version": "2.1.33",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "description": "RaaS Agency Operating System - Powered by Binh Phap & ClaudeKit DNA",
  "author": "Binh Phap Venture Studio",
  "license": "MIT",
  "homepage": "https://agencyos.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/longtho638-jpg/mekong-cli.git"
  },
  "bugs": {
    "url": "https://github.com/longtho638-jpg/mekong-cli/issues"
  },
  "workspaces": [
    "frontend",
    "packages/*",
    "packages/core/*",
    "packages/integrations/*",
    "packages/business/*",
    "packages/ui/*",
    "packages/tooling/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "cd apps/web && pnpm dev",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload --port 8000",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format"
  },
  "devDependencies": {
    "@types/node": "25.3.2",
    "concurrently": "^8.2.2",
    "turbo": "^2.1.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "sonner": "^2.0.7"
  }
}
