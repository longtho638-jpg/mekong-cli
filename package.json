{
  "name": "mekong-cli",
  "version": "2.1.33",
  "private": true,
  "description": "RaaS Agency Operating System - Powered by Binh Phap & ClaudeKit DNA",
  "author": "Binh Phap Venture Studio",
  "license": "MIT",
  "homepage": "https://agencyos.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/longtho638-jpg/mekong-cli.git"
  },
  "bugs": {
    "url": "https://github.com/longtho638-jpg/mekong-cli/issues"
  },
  "workspaces": [
    "frontend",
    "packages/*",
    "packages/core/*",
    "packages/integrations/*",
    "packages/business/*",
    "packages/ui/*",
    "packages/tooling/*",
    "apps/*"
  ],
  "scripts": {
    "dev:api": "cd api && poetry run uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:frontend\"",
    "build": "turbo run build",
    "build:api": "cd api && poetry build",
    "build:frontend": "cd frontend && npm run build",
    "test": "turbo run test",
    "test:api": "cd api && poetry run pytest",
    "test:frontend": "cd frontend && npm run test",
    "lint": "turbo run lint",
    "format": "turbo run format"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "turbo": "^2.1.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "sonner": "^2.0.7"
  }
}
