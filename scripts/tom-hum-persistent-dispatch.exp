#!/usr/bin/expect -f
# DEPRECATED: This expect script no longer works with CC CLI v2.1.38+
# CC CLI uses Ink (React TUI) which writes to alternate screen buffer,
# making expect PTY prompt detection impossible.
# Replaced by: apps/openclaw-worker/lib/brain-process-manager.js (v2)
# which uses claude -p (non-interactive print mode) directly.
#
# Kept as reference. Do not use in production.
#
# Original purpose: kept CC CLI alive across all missions via PTY.
# Usage: expect tom-hum-persistent-dispatch.exp <default_project_dir> <log_file>
# Missions read from: /tmp/tom_hum_next_mission.txt
# Done signal written: /tmp/tom_hum_mission_done

# --- Constants ---
set mission_file "/tmp/tom_hum_next_mission.txt"
set done_file    "/tmp/tom_hum_mission_done"
set poll_ms      3000
set mission_timeout 2700
set debounce_ms  500
set max_respawns_per_hour 5
set initial_ready_timeout 120

# --- Args ---
if {[llength $argv] < 2} {
    puts stderr "Usage: expect tom-hum-persistent-dispatch.exp <project_dir> <log_file>"
    exit 1
}
set default_dir [lindex $argv 0]
set log_file    [lindex $argv 1]

# --- Helpers ---
proc logmsg {msg} {
    global log_file
    set ts [clock format [clock seconds] -format "%Y-%m-%d %H:%M:%S"]
    set line "\[$ts\] $msg"
    if {$log_file ne ""} {
        catch {
            set f [open $log_file a]
            puts $f $line
            close $f
        }
    }
    puts stderr $line
}

proc strip_ansi {text} {
    # Remove CSI sequences (colors, cursor moves)
    set clean [regsub -all {\x1b\[[0-9;]*[a-zA-Z]} $text ""]
    # Remove OSC sequences (title bar, hyperlinks)
    set clean [regsub -all {\x1b\][^\x07]*\x07} $clean ""]
    # Remove other escape sequences
    set clean [regsub -all {\x1b[^\[]} $clean ""]
    return [string trim $clean]
}

proc spawn_cli {is_resume} {
    global default_dir spawn_id
    cd $default_dir
    # Antigravity Proxy — required for CC CLI to connect
    set ::env(ANTHROPIC_BASE_URL) "http://127.0.0.1:8080"
    set ::env(ANTHROPIC_API_KEY) "sk-6219c93290f14b32b047342ca8b0bea9"
    if {$is_resume} {
        logmsg "RESPAWN: claude --continue --model claude-opus-4-6-thinking --dangerously-skip-permissions"
        spawn claude --continue --model claude-opus-4-6-thinking --dangerously-skip-permissions
    } else {
        logmsg "SPAWN: claude --model claude-opus-4-6-thinking --dangerously-skip-permissions"
        spawn claude --model claude-opus-4-6-thinking --dangerously-skip-permissions
    }
    logmsg "CC CLI spawned (PID: $spawn_id)"
}

# Wait for the interactive prompt. Returns 1 on success, 0 on timeout/eof.
# Detects the UTF-8 prompt character or fallback "> " at end of line.
# Uses debounce: waits debounce_ms after detection to confirm stability.
proc wait_for_prompt {timeout_secs} {
    global debounce_ms
    set deadline [expr {[clock seconds] + $timeout_secs}]

    while {[clock seconds] < $deadline} {
        set remaining [expr {$deadline - [clock seconds]}]
        if {$remaining <= 0} { return 0 }

        expect {
            -re {(\xe2\x9d\xaf|❯)} {
                # Prompt candidate detected — debounce
                after $debounce_ms
                # Drain any further output that arrived during debounce
                expect {
                    -re {.+} {
                        # More output arrived — not actually idle, keep waiting
                        exp_continue
                    }
                    -timeout 1 {
                        # No more output after debounce — confirmed prompt
                        return 1
                    }
                }
            }
            -re {> \s*$} {
                # Fallback prompt detected — debounce
                after $debounce_ms
                expect {
                    -re {.+} { exp_continue }
                    -timeout 1 { return 1 }
                }
            }
            eof {
                logmsg "EOF during wait_for_prompt"
                return -1
            }
            -timeout $remaining {
                return 0
            }
        }
    }
    return 0
}

# --- Clean up from previous runs ---
file delete -force $done_file
file delete -force $mission_file

logmsg "=== PERSISTENT DISPATCH ONLINE ==="
logmsg "Project dir: $default_dir"
logmsg "Mission inbox: $mission_file"
logmsg "Done signal: $done_file"

# --- Outer crash recovery loop ---
log_user 0
set respawn_count 0
set respawn_hour_start [clock seconds]
set mission_count 0
set is_first_spawn 1

while {1} {
    # Rate-limit respawns
    set now [clock seconds]
    if {($now - $respawn_hour_start) > 3600} {
        set respawn_count 0
        set respawn_hour_start $now
    }
    if {$respawn_count >= $max_respawns_per_hour} {
        logmsg "ERROR: Max respawns ($max_respawns_per_hour/hour) reached. Sleeping 300s."
        sleep 300
        set respawn_count 0
        set respawn_hour_start [clock seconds]
    }

    # Spawn or respawn CC CLI
    if {$is_first_spawn} {
        spawn_cli 0
        set is_first_spawn 0
    } else {
        incr respawn_count
        logmsg "RESPAWN #$respawn_count — resuming with --continue"
        spawn_cli 1
    }

    # Wait for initial ready prompt
    logmsg "Waiting for CC CLI ready prompt (${initial_ready_timeout}s timeout)..."
    set ready [wait_for_prompt $initial_ready_timeout]
    if {$ready == -1} {
        logmsg "CC CLI crashed during startup — will retry"
        sleep 5
        continue
    }
    if {$ready == 0} {
        logmsg "TIMEOUT waiting for CC CLI ready prompt — will retry"
        catch { close; wait }
        sleep 5
        continue
    }
    logmsg "CC CLI READY — entering mission loop"

    # --- Mission loop ---
    set mission_loop_alive 1
    while {$mission_loop_alive} {
        # Poll for mission file
        if {![file exists $mission_file]} {
            sleep 3
            continue
        }

        # Read and consume mission
        set f [open $mission_file r]
        set mission_text [string trim [read $f]]
        close $f
        file delete -force $mission_file
        file delete -force $done_file

        if {$mission_text eq ""} {
            logmsg "Empty mission file — skipping"
            continue
        }

        incr mission_count
        set short_mission [string range $mission_text 0 120]
        logmsg "MISSION #$mission_count: $short_mission..."

        # Send mission to CC CLI
        sleep 1
        send -- "$mission_text\r"
        logmsg "Mission #$mission_count injected into CC CLI"

        # Monitor for completion
        set start_time [clock seconds]
        set last_status_log $start_time
        set completed 0

        while {!$completed} {
            set now [clock seconds]
            set elapsed [expr {$now - $start_time}]

            # Timeout check
            if {$elapsed > $mission_timeout} {
                logmsg "TIMEOUT: Mission #$mission_count after ${elapsed}s"
                catch {
                    set f [open $done_file w]
                    puts $f "timeout"
                    close $f
                }
                set completed 1
                break
            }

            # Status log every 60s
            if {($now - $last_status_log) >= 60} {
                logmsg "STATUS: Mission #$mission_count working -- ${elapsed}s"
                set last_status_log $now
            }

            expect {
                -re {(\xe2\x9d\xaf|❯)} {
                    # Prompt candidate — debounce
                    after $debounce_ms
                    expect {
                        -re {.+} {
                            # More output — not done yet
                            set raw $expect_out(0,string)
                            set clean [strip_ansi $raw]
                            if {[string length $clean] > 3} {
                                foreach pat {Bash Read Wrote Created Updated Error error build test COMPLETE fix success Running PASS FAIL} {
                                    if {[string match -nocase "*$pat*" $clean]} {
                                        logmsg "OUTPUT: [string range $clean 0 150]"
                                        break
                                    }
                                }
                            }
                            exp_continue
                        }
                        -timeout 1 {
                            # Confirmed prompt — mission done
                            set elapsed [expr {[clock seconds] - $start_time}]
                            logmsg "COMPLETE: Mission #$mission_count (${elapsed}s)"
                            catch {
                                set f [open $done_file w]
                                puts $f "done"
                                close $f
                            }
                            set completed 1
                        }
                    }
                }
                -re {> \s*$} {
                    # Fallback prompt — debounce
                    after $debounce_ms
                    expect {
                        -re {.+} { exp_continue }
                        -timeout 1 {
                            set elapsed [expr {[clock seconds] - $start_time}]
                            logmsg "COMPLETE: Mission #$mission_count (${elapsed}s) [fallback prompt]"
                            catch {
                                set f [open $done_file w]
                                puts $f "done"
                                close $f
                            }
                            set completed 1
                        }
                    }
                }
                -re {.+} {
                    # Log interesting patterns
                    set raw $expect_out(0,string)
                    set clean [strip_ansi $raw]
                    if {[string length $clean] > 3} {
                        foreach pat {Bash Read Wrote Created Updated Error error build test COMPLETE fix success Running PASS FAIL tool} {
                            if {[string match -nocase "*$pat*" $clean]} {
                                logmsg "OUTPUT: [string range $clean 0 150]"
                                break
                            }
                        }
                    }
                }
                eof {
                    set elapsed [expr {[clock seconds] - $start_time}]
                    logmsg "CRASH: CC CLI died during mission #$mission_count (${elapsed}s)"
                    catch {
                        set f [open $done_file w]
                        puts $f "crash"
                        close $f
                    }
                    set completed 1
                    set mission_loop_alive 0
                }
                -timeout 10 {
                    # Idle tick — just loop back for timeout/status checks
                }
            }
        }

        if {$mission_loop_alive} {
            logmsg "Mission #$mission_count finished. CC CLI stays alive. Waiting for next..."
        }
    }

    # If we got here, CC CLI crashed — outer loop will respawn
    logmsg "CC CLI lost — outer loop will respawn with --continue"
    catch { close; wait }
    sleep 3
}
