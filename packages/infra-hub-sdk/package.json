    "@agencyos/vibe-compliance-auto": "workspace:*",
    "@agencyos/vibe-consent": "workspace:*",
    "@agencyos/vibe-edge": "workspace:*",
    "@agencyos/vibe-bridge": "workspace:*"
  },
