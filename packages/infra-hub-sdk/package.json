      "optional": true
    },
    "@agencyos/vibe-identity": {
      "optional": true
    },
    "@agencyos/vibe-compliance": {
      "optional": true
    },
    "@agencyos/vibe-compliance-auto": {
      "optional": true
    },
    "@agencyos/vibe-consent": {
      "optional": true
    },
    "@agencyos/vibe-edge": {
      "optional": true
    },
