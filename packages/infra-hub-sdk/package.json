{
  "name": "@agencyos/infra-hub-sdk",
  "version": "0.1.0",
  "description": "Unified infrastructure SDK \u2014 auth, identity, compliance, consent, edge computing, bridge",
  "main": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": "./index.ts",
