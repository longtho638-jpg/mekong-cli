{
    "name": "@mekong/vibe-dev",
    "sideEffects": false,
  "version": "1.0.0",
    "description": "🟢 Earth - Development Workflow Layer - Bidirectional sync between GitHub Projects V2 and local JSON",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "vibe": "./dist/cli.js"
    },
    "scripts": {
        "build": "tsc",
        "test": "npm run test:sync-engine && npm run test:cli",
        "test:connection": "ts-node scripts/test-github-connection.ts",
        "test:sync-down": "ts-node scripts/test-sync-down.ts",
        "test:sync-up": "ts-node scripts/test-sync-up.ts",
        "test:sync-engine": "ts-node scripts/test-sync-engine.ts",
        "test:cli": "ts-node scripts/test-cli-integration.ts",
        "test:e2e": "ts-node scripts/test-e2e-real-github.ts",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "github",
        "projects",
        "projectsv2",
        "sync",
        "cli",
        "task-management",
        "graphql",
        "workflow",
        "automation"
    ],
    "author": "AgencyOS",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/agencyos/vibe-dev.git"
    },
    "bugs": {
        "url": "https://github.com/agencyos/vibe-dev/issues"
    },
    "homepage": "https://github.com/agencyos/vibe-dev#readme",
    "engines": {
        "node": ">=18.0.0"
    },
    "files": [
        "dist/",
        "README.md",
        "LICENSE",
        "CHANGELOG.md"
    ],
    "dependencies": {
        "@mekong/vibe-analytics": "workspace:*",
        "@stripe/stripe-js": "^2.4.0",
        "@types/inquirer": "^9.0.9",
        "chalk": "^4.1.2",
        "commander": "^11.1.0",
        "dotenv": "^17.2.4",
        "inquirer": "^8.2.6",
        "stripe": "^20.3.1"
    },
    "devDependencies": {
        "@types/node": "^20.19.32",
        "@types/stripe": "^8.0.416",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3"
    }
}
