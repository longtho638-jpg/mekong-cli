# Local LLM Environment Variables
# Copy this file to .env.local

# Ollama Configuration
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.2:3b
LLM_API_KEY=ollama

# Optional: Fallback to cloud provider
# OPENROUTER_API_KEY=sk-or-v1-xxx
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Polar.sh Payment Configuration (ROIaaS Phase 3)
# Get webhook secret from Polar Dashboard > Settings > Webhooks
POLAR_WEBHOOK_SECRET=whsec_xxx
# Get product ID from Polar Dashboard > Products
POLAR_PRODUCT_ID=prod_xxx
