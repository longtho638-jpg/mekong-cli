{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist/worker",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "noEmit": false,
    "declaration": false
  },
  "include": ["src/api/gateway.ts"],
  "exclude": ["node_modules", "**/*.test.ts"]
}
