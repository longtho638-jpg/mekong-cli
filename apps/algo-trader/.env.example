# Polar.sh API Configuration
POLAR_API_KEY=sk_live_REPLACE_WITH_YOUR_KEY
POLAR_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_SECRET
POLAR_PRO_BENEFIT_ID=ben_pro_monthly
POLAR_ENTERPRISE_BENEFIT_ID=ben_ent_monthly

# Checkout URLs
POLAR_SUCCESS_URL=https://algo-trader.local/upgrade/success
POLAR_CANCEL_URL=https://algo-trader.local/upgrade/cancelled

# License Service
RAAS_LICENSE_SECRET=CHANGE_ME_TO_32_CHAR_SECRET_MIN_LENGTH

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/algo_trader?schema=public"
# For local testing with SQLite, use: DATABASE_URL="file:./dev.db"

# Server Configuration
NODE_ENV=production
API_PORT=3000
LOG_LEVEL=info

# Cloudflare Workers AI (for local testing)
# In Workers runtime, uses AI binding automatically
CF_ACCOUNT_ID=your_account_id
CF_API_TOKEN=your_api_token_with_ai_write_permission
# Model: @cf/meta/llama-3-8b-instruct (default), @cf/qwen/qwen-1.5-7b-chat-awq, etc.
