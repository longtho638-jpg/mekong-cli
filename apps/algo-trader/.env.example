# =============================================================================
# AGI Algo Trader — Environment Configuration
# Copy to .env and fill in your API keys: cp .env.example .env
# =============================================================================

# ─── Exchange API Keys (Required for live trading) ───────────────────────────
# Get from: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET=your_binance_secret

# Get from: https://www.okx.com/account/my-api
OKX_API_KEY=your_okx_api_key
OKX_SECRET=your_okx_secret

# Get from: https://www.bybit.com/app/user/api-management
BYBIT_API_KEY=your_bybit_api_key
BYBIT_SECRET=your_bybit_secret

# Legacy single-exchange mode
EXCHANGE_ID=binance
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_SECRET=your_secret_here

# ─── Trading Configuration ───────────────────────────────────────────────────
TRADING_PAIR=BTC/USDT
TIMEFRAME=1h

# Strategy parameters
RSI_PERIOD=14
SMA_SHORT=20
SMA_LONG=50

# ─── Risk Management ─────────────────────────────────────────────────────────
MAX_POSITION_SIZE=0.01
STOP_LOSS_PCT=2.0
TAKE_PROFIT_PCT=5.0
MAX_DAILY_LOSS=100

# ─── Telegram Alerts (Optional) ──────────────────────────────────────────────
# Create bot: https://t.me/BotFather → /newbot
# Get chat ID: https://t.me/userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Infrastructure (Docker Compose auto-configures these) ───────────────────
DATABASE_URL=postgresql://algo_trader:algo_trader_dev@localhost:5432/algo_trader
REDIS_URL=redis://localhost:6379
API_PORT=3000
METRICS_ENABLED=true

# ─── Monitoring ──────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=algo-trader.log
GRAFANA_PASSWORD=admin

# ─── Billing (Polar.sh) ─────────────────────────────────────────────────────
POLAR_WEBHOOK_SECRET=your_polar_webhook_secret
POLAR_PRODUCT_FREE=prod_free
POLAR_PRODUCT_PRO=prod_pro
POLAR_PRODUCT_ENTERPRISE=prod_enterprise
APP_URL=http://localhost:3000

# ─── Feature Flags ───────────────────────────────────────────────────────────
ENABLE_BACKTESTING=false
ENABLE_LIVE_TRADING=false
