     1→# Exchange Configuration
     2→EXCHANGE_ID=binance
     3→EXCHANGE_API_KEY=your_api_key_here
     4→EXCHANGE_SECRET=your_secret_here
     5→
     6→# Trading Configuration
     7→TRADING_PAIR=BTC/USDT
     8→TIMEFRAME=1h
     9→RSI_PERIOD=14
    10→SMA_SHORT=20
    11→SMA_LONG=50
    12→
    13→# Risk Management
    14→MAX_POSITION_SIZE=0.01
    15→STOP_LOSS_PCT=2.0
    16→TAKE_PROFIT_PCT=5.0
    17→MAX_DAILY_LOSS=100
    18→
    19→# Logging
    20→LOG_LEVEL=info
    21→LOG_FILE=algo-trader.log
    22→
    23→# Backtesting Configuration
    24→ENABLE_BACKTESTING=false
    25→# Live Trading Configuration
    26→ENABLE_LIVE_TRADING=false

# Cross-Exchange Arbitrage (arb:engine)
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET=your_binance_secret
OKX_API_KEY=your_okx_api_key
OKX_SECRET=your_okx_secret
BYBIT_API_KEY=your_bybit_api_key
BYBIT_SECRET=your_bybit_secret

# Infrastructure (Docker Compose)
DATABASE_URL=postgresql://algo_trader:algo_trader_dev@localhost:5432/algo_trader
REDIS_URL=redis://localhost:6379
API_PORT=3000
METRICS_ENABLED=true

# Grafana (docker-compose only)
GRAFANA_PASSWORD=admin

# Polar.sh Billing
POLAR_WEBHOOK_SECRET=your_polar_webhook_secret
POLAR_PRODUCT_FREE=prod_free
POLAR_PRODUCT_PRO=prod_pro
POLAR_PRODUCT_ENTERPRISE=prod_enterprise
APP_URL=http://localhost:3000
