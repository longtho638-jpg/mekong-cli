{
  "accounts": {
    "binance": [
      { "id": "vip1", "apiKeyEnv": "BINANCE_VIP1_API_KEY", "secretEnv": "BINANCE_VIP1_SECRET", "enabled": true }
    ],
    "bybit": [
      { "id": "main", "apiKeyEnv": "BYBIT_API_KEY", "secretEnv": "BYBIT_SECRET", "enabled": true }
    ]
  },
  "proxyPool": {
    "provider": "brightdata",
    "apiTokenEnv": "BRIGHTDATA_TOKEN",
    "rotationIntervalSec": 30,
    "maxConcurrentProxies": 50,
    "healthCheckUrl": "https://api.binance.com/api/v3/ping",
    "stickySession": false,
    "fallbackToDirect": true
  },
  "ghostConfig": {
    "jitterMeanMs": 8,
    "jitterStdMs": 3,
    "fingerprintRotation": "perRequest",
    "webSocketShards": 5,
    "chameleonActions": ["cancelRandom", "tinyOrder"]
  },
  "antiBotMonitor": {
    "rateLimitThreshold": 5,
    "slippageSpikeThresholdBps": 20,
    "cooldownMinutes": 10
  },
  "complianceLogPath": "./logs/compliance/",
  "canaryMode": true
}
