{
  "name": "algo-trader",
  "version": "0.1.0",
  "description": "Modular algo trading bot with RSI+SMA strategy",
  "main": "dist/index.js",
  "scripts": {
    "disk:check": "pnpm exec ts-node scripts/disk-monitor.ts",
    "disk:check:sh": "bash scripts/pre-build-check.sh",
    "prebuild": "npm run disk:check",
    "build": "tsc",
    "build:fast": "tsc --incremental",
    "build:clean": "rm -rf dist && tsc",
    "build:watch": "tsc --watch",
    "build:cached": "bash scripts/build-with-cache.sh",
    "cache:check": "pnpm exec ts-node src/utils/build-cache.ts check",
    "cache:restore": "pnpm exec ts-node src/utils/build-cache.ts restore",
    "cache:save": "pnpm exec ts-node src/utils/build-cache.ts save",
    "cache:cleanup": "pnpm exec ts-node src/utils/build-cache.ts cleanup",
    "start": "node dist/index.js",
    "dev": "pnpm exec ts-node src/index.ts",
    "setup": "pnpm exec ts-node src/index.ts setup",
    "quickstart": "pnpm exec ts-node src/index.ts quickstart",
    "telegram": "pnpm exec ts-node src/index.ts telegram:bot",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:load": "k6 run tests/load/raas-gateway-load-test.js",
    "test:load:ci": "k6 run --quiet tests/load/raas-gateway-load-test.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit --pretty",
    "dashboard:dev": "cd dashboard && npx vite",
    "dashboard:build": "cd dashboard && npx vite build",
    "api:serve": "pnpm exec ts-node src/index.ts api:serve",
    "build:worker": "tsc -p tsconfig.worker.json && npm run disk:check",
    "dev:worker": "wrangler dev",
    "sync-dunning-kv": "ts-node src/jobs/dunning-kv-sync.ts",
    "audit": "pnpm exec ts-node src/audit/index.ts",
    "chaos-test": "pnpm exec ts-node src/testing/chaos/index.ts"
  },
  "dependencies": {
    "@agencyos/trading-core": "workspace:*",
    "@agencyos/vibe-arbitrage-engine": "workspace:*",
    "@agencyos/vibe-billing-trading": "workspace:*",
    "@fastify/cors": "^10.1.0",
    "@fastify/static": "9.0.0",
    "@hono/node-server": "^1.14.0",
    "@polar-sh/sdk": "^0.41.5",
    "@prisma/client": "5.21.1",
    "@aws-sdk/client-s3": "^3.0.0",
    "@tensorflow/tfjs": "4.22.0",
    "bullmq": "^5.41.0",
    "ccxt": "^4.5.40",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "dotenv": "^16.6.1",
    "fastify": "5.7.4",
    "fastify-plugin": "^5.1.0",
    "fs-extra": "^11.2.0",
    "hono": "^4.7.0",
    "ioredis": "^5.6.0",
    "jose": "^6.1.3",
    "pg": "^8.19.0",
    "stripe": "^17.7.0",
    "technicalindicators": "^3.1.0",
    "winston": "^3.19.0",
    "ws": "^8.19.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "@playwright/test": "^1.40.0",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.35",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.18.1",
    "ioredis-mock": "^8.9.0",
    "jest": "^29.7.0",
    "pkg-dir": "9.0.0",
    "prisma": "5.21.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "wrangler": "^3.101.0",
    "yaml": "^2.8.2"
  }
}
