{
  "name": "algo-trader",
  "version": "0.1.0",
  "description": "Modular algo trading bot with RSI+SMA strategy",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "setup": "ts-node src/index.ts setup",
    "quickstart": "ts-node src/index.ts quickstart",
    "telegram": "ts-node src/index.ts telegram:bot",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit --pretty",
    "dashboard:dev": "cd dashboard && npx vite",
    "dashboard:build": "cd dashboard && npx vite build",
    "api:serve": "ts-node src/index.ts api:serve"
  },
  "dependencies": {
    "@agencyos/trading-core": "workspace:*",
    "@agencyos/vibe-arbitrage-engine": "workspace:*",
    "@agencyos/vibe-billing-trading": "workspace:*",
    "@fastify/cors": "^10.1.0",
    "@fastify/static": "9.0.0",
    "@polar-sh/sdk": "^0.41.5",
    "@prisma/client": "5.21.1",
    "@tensorflow/tfjs": "4.22.0",
    "bullmq": "^5.41.0",
    "ccxt": "^4.5.40",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "dotenv": "^16.6.1",
    "fastify": "5.7.4",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.6.0",
    "pg": "^8.19.0",
    "technicalindicators": "^3.1.0",
    "winston": "^3.19.0",
    "ws": "^8.19.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.35",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.18.1",
    "ioredis-mock": "^8.9.0",
    "jest": "^29.7.0",
    "pkg-dir": "9.0.0",
    "prisma": "5.21.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "yaml": "^2.8.2"
  }
}
