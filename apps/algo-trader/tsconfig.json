{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "jsx": "react",
    "types": ["node", "jest", "react"],
    "isolatedModules": false,
    "typeRoots": ["./node_modules/@types", "../../node_modules/@types", "../../node_modules/.pnpm/node_modules/@types", "../../packages/trading-core/types"],
    "paths": {
      "@agencyos/trading-core": ["../../packages/trading-core/index.ts"],
      "@agencyos/trading-core/*": ["../../packages/trading-core/*"],
      "@agencyos/vibe-billing-trading": ["../../packages/vibe-billing-trading/index.ts"],
      "@agencyos/vibe-billing-trading/*": ["../../packages/vibe-billing-trading/*"],
      "@agencyos/vibe-arbitrage-engine": ["../../packages/vibe-arbitrage-engine/index.ts"],
      "@agencyos/vibe-arbitrage-engine/*": ["../../packages/vibe-arbitrage-engine/*"]
    },
    "incremental": true,
    "composite": false,
    "declaration": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "node_modules/.cache",
    "src/api/routes/monitoring-routes.ts",
    "src/api/routes/monitoring-routes-extension.ts",
    "../../packages/**/*.ts",
    "src/arbitrage/**/*.ts",
    "src/cli/**/*.ts"
  ]
}
