    "enabled": false,
    "rlModel": "qlearning",
    "noiseActions": ["cancel", "tinyOrder", "guiCheck", "doNothing"],
    "detectionThreshold": 0.8,
    "noiseIntervalMs": 60000
  },
  "leverage": {
    "free": 1,
    "pro": 10,
    "enterprise": 20
  }
}
