{
  "_doc": "OpenClaw Tôm Hùm — Autonomous Trading Company Schedule",
  "_version": "1.0.0",
  "_created": "2026-03-03",

  "thresholds": {
    "halt_drawdown": 0.20,
    "halt_cb_count": 3,
    "escalate_capital_change": 0.10,
    "auto_fix_weight_drift": 0.05,
    "auto_fix_fee_ratio": 0.20
  },

  "schedules": [
    {
      "id": "hourly-health",
      "cron": "0 * * * *",
      "description": "System health pulse — exchange, pipeline, uptime",
      "missions": [
        { "role": "exec-spec", "action": "health", "timeout": "SIMPLE", "tier": "AUTO" },
        { "role": "sre", "action": "uptime", "timeout": "SIMPLE", "tier": "AUTO" },
        { "role": "data-eng", "action": "health", "timeout": "SIMPLE", "tier": "AUTO" }
      ],
      "parallel": true,
      "enabled": true
    },
    {
      "id": "every-4h-trading",
      "cron": "0 */4 * * *",
      "description": "Trading intelligence refresh — signals, risk, regime",
      "missions": [
        { "role": "auto", "action": "fast", "timeout": "MEDIUM", "tier": "AUTO" },
        { "role": "risk-analyst", "action": "var", "timeout": "SIMPLE", "tier": "AUTO" },
        { "role": "market-analyst", "action": "regime", "timeout": "SIMPLE", "tier": "AUTO" }
      ],
      "parallel": false,
      "enabled": true
    },
    {
      "id": "daily-ops",
      "cron": "0 8 * * *",
      "description": "Daily operations — health, P&L, security, code quality",
      "missions": [
        { "role": "coo", "action": "health", "timeout": "MEDIUM", "tier": "AUTO" },
        { "role": "cfo", "action": "review", "timeout": "MEDIUM", "tier": "AUTO" },
        { "role": "fin-analyst", "action": "pnl", "timeout": "SIMPLE", "tier": "AUTO" },
        { "role": "sec-analyst", "action": "scan", "timeout": "SIMPLE", "tier": "AUTO" },
        { "role": "backend", "action": "quality", "timeout": "SIMPLE", "tier": "AUTO_FIX" },
        { "role": "ml-eng", "action": "learning", "timeout": "SIMPLE", "tier": "AUTO" },
        { "role": "quant", "action": "alpha", "timeout": "SIMPLE", "tier": "AUTO" },
        { "role": "market-analyst", "action": "intel", "timeout": "SIMPLE", "tier": "AUTO" }
      ],
      "parallel": false,
      "enabled": true
    },
    {
      "id": "weekly-review",
      "cron": "0 9 * * 1",
      "description": "Monday full review — all C-suite + subordinates",
      "missions": [
        { "role": "all", "action": "quick weekly", "timeout": "COMPLEX", "tier": "REPORT" }
      ],
      "parallel": false,
      "enabled": true
    },
    {
      "id": "weekly-deep",
      "cron": "0 14 * * 3",
      "description": "Wednesday deep dives — risk, strategy, growth",
      "missions": [
        { "role": "ceo", "action": "dashboard", "timeout": "MEDIUM", "tier": "AUTO" },
        { "role": "coo", "action": "perf", "timeout": "MEDIUM", "tier": "AUTO" },
        { "role": "cfo", "action": "costs", "timeout": "MEDIUM", "tier": "AUTO" },
        { "role": "cdo", "action": "audit", "timeout": "MEDIUM", "tier": "AUTO" },
        { "role": "cpo", "action": "roadmap", "timeout": "MEDIUM", "tier": "AUTO" },
        { "role": "cto", "action": "audit", "timeout": "MEDIUM", "tier": "AUTO" },
        { "role": "caio", "action": "audit", "timeout": "MEDIUM", "tier": "AUTO" },
        { "role": "cso", "action": "audit", "timeout": "MEDIUM", "tier": "AUTO" },
        { "role": "growth", "action": "funnel", "timeout": "SIMPLE", "tier": "AUTO" },
        { "role": "product-analyst", "action": "metrics", "timeout": "SIMPLE", "tier": "AUTO" },
        { "role": "risk-analyst", "action": "stress", "timeout": "MEDIUM", "tier": "AUTO" },
        { "role": "founder", "action": "strategy", "timeout": "MEDIUM", "tier": "REPORT" }
      ],
      "parallel": false,
      "enabled": true
    },
    {
      "id": "monthly-full",
      "cron": "0 9 1 * *",
      "description": "1st of month — full 26-role review + financial",
      "missions": [
        { "role": "all", "action": "full monthly", "timeout": "STRATEGIC", "tier": "ESCALATE" },
        { "role": "ceo", "action": "allocate", "timeout": "MEDIUM", "tier": "ESCALATE" },
        { "role": "cfo", "action": "tax", "timeout": "MEDIUM", "tier": "REPORT" },
        { "role": "cfo", "action": "model", "timeout": "MEDIUM", "tier": "REPORT" },
        { "role": "cmo", "action": "content", "timeout": "MEDIUM", "tier": "AUTO" },
        { "role": "chro", "action": "audit", "timeout": "SIMPLE", "tier": "AUTO" },
        { "role": "cxo", "action": "audit", "timeout": "SIMPLE", "tier": "AUTO" },
        { "role": "cco", "action": "review", "timeout": "MEDIUM", "tier": "REPORT" },
        { "role": "founder", "action": "budget", "timeout": "MEDIUM", "tier": "ESCALATE" }
      ],
      "parallel": false,
      "enabled": true
    },
    {
      "id": "quarterly-strategic",
      "cron": "0 9 1 1,4,7,10 *",
      "description": "Quarterly strategic — CEO risk, CPO features, quant discovery",
      "missions": [
        { "role": "all", "action": "full quarterly", "timeout": "STRATEGIC", "tier": "ESCALATE" },
        { "role": "ceo", "action": "risk", "timeout": "COMPLEX", "tier": "ESCALATE" },
        { "role": "cpo", "action": "prioritize", "timeout": "MEDIUM", "tier": "REPORT" },
        { "role": "quant", "action": "discover", "timeout": "COMPLEX", "tier": "REPORT" },
        { "role": "growth", "action": "experiment", "timeout": "MEDIUM", "tier": "REPORT" }
      ],
      "parallel": false,
      "enabled": true
    }
  ],

  "tiers": {
    "AUTO": "Execute and continue. No approval needed.",
    "AUTO_FIX": "Execute fix if issue found. Log action.",
    "REPORT": "Execute and send report to Chairman. No approval needed.",
    "ESCALATE": "Execute audit only. Changes require Chairman approval."
  }
}
