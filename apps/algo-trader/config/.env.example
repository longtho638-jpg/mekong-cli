# ═══════════════════════════════════════════════════════════════
# OpenClaw Trading Company — Client Configuration
# Copy this to .env and fill in your values:
#   cp config/.env.example config/.env
# ═══════════════════════════════════════════════════════════════

# ─── LLM PROVIDER (choose 1 or more) ─────────────────────────
# Option 1: Anthropic Claude
ANTHROPIC_API_KEY=

# Option 2: OpenAI
OPENAI_API_KEY=

# Option 3: Google Gemini
GOOGLE_API_KEY=

# Option 4: Local Ollama (no key needed — use Profile local-llm)
# OLLAMA_HOST=http://ollama:11434

# ─── EXCHANGE API KEYS ───────────────────────────────────────
# Binance
BINANCE_API_KEY=
BINANCE_SECRET=

# OKX
OKX_API_KEY=
OKX_SECRET=
OKX_PASSPHRASE=

# Bybit
BYBIT_API_KEY=
BYBIT_SECRET=

# ─── TRADING SETTINGS ────────────────────────────────────────
TRADING_MODE=paper
INITIAL_CAPITAL_USD=1000
MAX_DAILY_LOSS_USD=100
MAX_DRAWDOWN_PCT=20

# ─── SYSTEM ──────────────────────────────────────────────────
DB_PASSWORD=changeme
DASHBOARD_PORT=8080
LITELLM_MASTER_KEY=changeme
TZ=UTC

# ─── ALERTS (optional) ───────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# DISCORD_WEBHOOK_URL=
