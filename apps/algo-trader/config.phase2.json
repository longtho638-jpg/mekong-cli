{
  "zeroShotSynthesizer": {
    "enabled": false,
    "pollIntervalMs": 30000,
    "minSharpeRatio": 1.5,
    "llm": {
      "endpoint": "http://localhost:11434/v1",
      "model": "llama3:8b-instruct-q4_0",
      "temperature": 0.2,
      "maxTokens": 512
    },
    "socialStreams": {
      "twitter": { "enabled": false, "keywords": ["BTC", "ETH", "crypto"] },
      "telegram": { "enabled": false, "channels": [] }
    }
  },
  "crossChainFlashLoans": {
    "enabled": false,
    "minNetProfitUsd": 10,
    "maxHops": 5,
    "enableFlashLoans": true,
    "rpcEndpoints": {
      "ethereum": "https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY",
      "solana": "https://api.mainnet-beta.solana.com",
      "bsc": "https://bsc-dataseed.binance.org"
    },
    "flashLoanProviders": ["aave_v3", "dydx", "port_finance"]
  },
  "adversarialMM": {
    "enabled": false,
    "modelPath": "./models/spoof-detector.onnx",
    "windowMs": 5000,
    "minConfidence": 0.6,
    "spoofAvoidThreshold": 0.7,
    "fadeThreshold": 0.9,
    "fadeSpreadMultiplier": 1.5
  }
}
