// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Tier {
  FREE
  PRO
  ENTERPRISE
}

enum StrategyStatus {
  ACTIVE
  PAUSED
  STOPPED
}

enum Side {
  BUY
  SELL
}

model Tenant {
  id               String           @id
  name             String
  email            String?
  tier             Tier             @default(FREE)
  maxStrategies    Int              @default(1)
  maxDailyLossUsd  Decimal          @default(100) @db.Decimal(12, 2)
  maxPositionUsd   Decimal          @default(1000) @db.Decimal(12, 2)
  allowedExchanges String[]         @default([])
  apiKeys          ApiKey[]
  strategies       Strategy[]
  trades           Trade[]
  backtestResults  BacktestResult[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@map("tenants")
}

model ApiKey {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  keyHash   String    @unique
  keyPrefix String
  scopes    String[]  @default([])
  isActive  Boolean   @default(true)
  lastUsed  DateTime?
  createdAt DateTime  @default(now())

  @@map("api_keys")
}

model Strategy {
  id          String         @id
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  name        String
  config      Json           @default("{}")
  status      StrategyStatus @default(PAUSED)
  pnl         Decimal        @default(0) @db.Decimal(12, 2)
  tradesCount Int            @default(0)
  startedAt   DateTime?
  createdAt   DateTime       @default(now())
  trades      Trade[]

  @@map("strategies")
}

model Trade {
  id         BigInt   @id @default(autoincrement())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  strategyId String
  strategy   Strategy @relation(fields: [strategyId], references: [id])
  pair       String
  side       Side
  price      Decimal  @db.Decimal(18, 8)
  amount     Decimal  @db.Decimal(18, 8)
  fee        Decimal  @default(0) @db.Decimal(12, 8)
  pnl        Decimal? @db.Decimal(12, 2)
  exchange   String
  executedAt DateTime @default(now())

  @@index([tenantId, executedAt(sort: Desc)])
  @@map("trades")
}

model BacktestResult {
  id          BigInt   @id @default(autoincrement())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  strategyId  String
  pair        String
  timeframe   String
  days        Int
  result      Json
  sharpe      Decimal? @db.Decimal(6, 3)
  maxDd       Decimal? @db.Decimal(6, 3)
  totalReturn Decimal? @db.Decimal(8, 3)
  createdAt   DateTime @default(now())

  @@map("backtest_results")
}

model Candle {
  time     DateTime
  pair     String
  exchange String
  open     Decimal  @db.Decimal(18, 8)
  high     Decimal  @db.Decimal(18, 8)
  low      Decimal  @db.Decimal(18, 8)
  close    Decimal  @db.Decimal(18, 8)
  volume   Decimal  @db.Decimal(18, 8)

  @@id([time, pair, exchange])
  @@index([pair, exchange, time(sort: Desc)])
  @@map("candles")
}

model PnlSnapshot {
  id            BigInt   @id @default(autoincrement())
  tenantId      String
  totalPnl      Decimal  @db.Decimal(12, 2)
  realizedPnl   Decimal  @db.Decimal(12, 2)
  unrealizedPnl Decimal  @db.Decimal(12, 2)
  openPositions Int      @default(0)
  equity        Decimal  @db.Decimal(12, 2)
  snapshotAt    DateTime @default(now())

  @@index([tenantId, snapshotAt(sort: Desc)])
  @@map("pnl_snapshots")
}

model License {
  id        String    @id @default(cuid())
  key       String    @unique
  tier      Tier
  tenantId  String?
  status    String    @default("active") // active, revoked, expired
  expiresAt DateTime?
  metadata  Json      @default("{}")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  revokedAt DateTime?
  revokedBy String?

  // Phase 6: Relations to entitlement models
  featureFlags         LicenseFeatureFlag[]
  extensionEligibility ExtensionEligibility[]
  usageAnalytics       UsageAnalytics[]
  tierExtensions       TierExtension[]

  @@index([key])
  @@index([tenantId])
  @@index([status])
  @@map("licenses")
}

model LicenseAuditLog {
  id        BigInt   @id @default(autoincrement())
  licenseId String
  event     String // created, activated, revoked, validated, expired
  tier      String?
  ip        String?
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([licenseId, createdAt(sort: Desc)])
  @@map("license_audit_logs")
}

model UsageEvent {
  id         String   @id @default(uuid())
  licenseKey String
  tenantId   String?
  eventType  String // api_call, compute_minute, ml_inference
  units      Int
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([licenseKey, createdAt])
  @@index([tenantId, createdAt])
  @@map("usage_events")
}

enum DunningStatus {
  ACTIVE
  GRACE_PERIOD
  SUSPENDED
  REVOKED
}

model DunningState {
  id                     String        @id @default(uuid())
  tenantId               String        @unique
  status                 DunningStatus @default(ACTIVE)
  failedPayments         Int           @default(0)
  currentPeriodEnd       DateTime?
  gracePeriodDays        Int           @default(7)
  suspendedAt            DateTime?
  revokedAt              DateTime?
  lastPaymentFailedAt    DateTime?
  lastPaymentRecoveredAt DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@index([status])
  @@index([tenantId, status])
  @@map("dunning_states")
}

model DunningEvent {
  id        String   @id @default(uuid())
  tenantId  String
  eventType String // payment_failed, grace_started, suspended, revoked, payment_recovered, overage_charged
  severity  String? // info, warning, critical
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([eventType])
  @@map("dunning_events")
}

// SEC/FINRA Compliance Audit Log - Append-only, immutable
model AuditLog {
  id        String  @id @default(uuid())
  eventType String // order_created, order_filled, order_cancelled, state_transition, etc.
  tenantId  String
  orderId   String?
  userId    String // Who triggered the event
  severity  String // info, warning, error, critical
  payload   Json // Full event data
  ipAddress String?
  userAgent String?

  // SEC/FINRA CAT (Consolidated Audit Trail) fields
  catOrderRef      String? // CAT Order Reference
  catEventCategory String? // CAT Event Category (2.0, 2.1, etc.)

  // Additional order context
  symbol String?
  side   String? // buy/sell
  amount Decimal? @db.Decimal(18, 8)
  price  Decimal? @db.Decimal(18, 8)

  // Hash chain fields for tamper evidence
  prevHash String? // SHA-256 of previous log entry
  hash     String? // SHA-256 hash of this entry

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([orderId])
  @@index([eventType])
  @@index([userId])
  @@map("audit_logs")
}

// Phase 6: Feature Flags - Granular feature entitlements
model FeatureFlag {
  id                Int                  @id @default(autoincrement())
  name              String               @unique
  description       String?
  enabled           Boolean              @default(true)
  rolloutPercentage Int                  @default(100)
  userWhitelist     Json                 @default("[]")
  metadata          Json                 @default("{}")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  licenses          LicenseFeatureFlag[]

  @@index([enabled])
  @@map("feature_flags")
}

// Phase 6: License-FeatureFlag junction table
model LicenseFeatureFlag {
  id            Int         @id @default(autoincrement())
  licenseId     String
  featureFlagId Int
  enabled       Boolean     @default(true)
  overrideValue Json?
  createdAt     DateTime    @default(now())
  license       License     @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  featureFlag   FeatureFlag @relation(fields: [featureFlagId], references: [id], onDelete: Cascade)

  @@unique([licenseId, featureFlagId])
  @@index([licenseId])
  @@index([featureFlagId])
  @@map("license_feature_flags")
}

// Phase 6: Extension Eligibility - Track extension access per license
model ExtensionEligibility {
  id            Int       @id @default(autoincrement())
  licenseId     String
  extensionName String
  eligible      Boolean   @default(false)
  status        String    @default("pending") // pending, approved, denied, revoked
  usageCount    Int       @default(0)
  usageLimit    Int       @default(1000)
  resetAt       DateTime?
  approvedAt    DateTime?
  deniedAt      DateTime?
  metadata      Json      @default("{}")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  license       License   @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@unique([licenseId, extensionName])
  @@index([licenseId])
  @@index([status])
  @@map("extension_eligibility")
}

// Phase 6: Usage Analytics - Detailed usage breakdown per feature
model UsageAnalytics {
  id           Int      @id @default(autoincrement())
  licenseId    String
  featureFlag  String?
  endpoint     String
  method       String
  requestCount Int      @default(0)
  payloadSize  BigInt   @default(0)
  hourBucket   DateTime @default(now())
  createdAt    DateTime @default(now())
  license      License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@unique([licenseId, featureFlag, endpoint, method, hourBucket])
  @@index([licenseId])
  @@index([hourBucket])
  @@map("usage_analytics")
}

// Phase 6: Tier Extension Requests
model TierExtension {
  id            String    @id @default(uuid())
  licenseId     String
  requestedTier String
  reason        String
  status        String    @default("pending") // pending, approved, denied
  approvedBy    String?
  approvedAt    DateTime?
  deniedAt      DateTime?
  metadata      Json      @default("{}")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  license       License   @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@index([licenseId])
  @@index([status])
  @@map("tier_extensions")
}

// Polymarket-specific models
model PolymarketPosition {
  id          String   @id @default(uuid())
  tenantId    String
  tokenId     String
  marketId    String
  side        String   // YES/NO
  size        Decimal
  avgPrice    Decimal
  realizedPnl Decimal  @default(0)
  openedAt    DateTime @default(now())
  closedAt    DateTime?

  @@index([tenantId, tokenId])
  @@map("polymarket_positions")
}

model PolymarketOrder {
  id          String   @id @default(uuid())
  tenantId    String
  tokenId     String
  side        String   // BUY/SELL
  size        Decimal
  price       Decimal
  orderType   String   // GTC/GTD/FOK
  status      String   // pending/filled/cancelled
  orderId     String   @unique
  createdAt   DateTime @default(now())
  filledAt    DateTime?

  @@index([tenantId, orderId])
  @@map("polymarket_orders")
}

model KalshiPosition {
  id          String   @id @default(uuid())
  tenantId    String
  ticker      String
  side        String   // yes/no
  count       Decimal
  avgPrice    Decimal
  realizedPnl Decimal  @default(0)
  openedAt    DateTime @default(now())
  closedAt    DateTime?

  @@index([tenantId, ticker])
  @@map("kalshi_positions")
}

model BinanceListingAlert {
  id        String   @id @default(uuid())
  ticker    String
  name      String
  detectedAt DateTime @default(now())
  processed Boolean  @default(false)
  signalId  String?

  @@index([ticker, detectedAt])
  @@map("binance_listing_alerts")
}
