{
  "scanPaths": [
    "src/arbitrage",
    "src/core",
    "src/execution",
    "src/api",
    "src/billing",
    "src/auth",
    "src/lib",
    "src/ml",
    "src/strategies"
  ],
  "excludePaths": ["node_modules", "dist", "coverage", "tests"],
  "securityChecks": [
    "hardcodedSecrets",
    "unsafeEval",
    "insecureRandom",
    "inputValidation",
    "sqlInjection"
  ],
  "dependencyAudit": true,
  "outputFormat": "html",
  "outputPath": "audit_report.html",
  "severity": {
    "critical": 10,
    "high": 7,
    "medium": 4,
    "low": 1
  }
}
