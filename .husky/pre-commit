#!/bin/sh
# 🏯 PRE-COMMIT HOOK - Binh Pháp CI Protection Layer 1
# Runs BEFORE commit is created

echo "🔍 Pre-commit: Running quick checks..."

# Python lint (if ruff available) — only check staged .py files
if command -v ruff &> /dev/null; then
    STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM -- '*.py' 2>/dev/null)
    if [ -n "$STAGED_PY" ]; then
        echo "   → Ruff lint (staged files only)..."
        echo "$STAGED_PY" | xargs ruff check --fix --quiet || {
            echo "❌ Ruff lint failed. Fix errors before committing."
            exit 1
        }
    fi
fi

# TypeScript check (dashboard only - quick)
if [ -f "apps/dashboard/tsconfig.json" ]; then
    echo "   → TypeScript check..."
    cd apps/dashboard
    pnpm exec tsc --noEmit --skipLibCheck 2>/dev/null || {
        echo "❌ TypeScript errors found. Fix before committing."
        exit 1
    }
    cd ../..
fi

# Critical payment tests (fast subset only)
if [ -d "backend/tests/unit" ]; then
    echo "   → Critical payment tests..."

    # Determine pytest command
    if [ -f "backend/.venv/bin/pytest" ]; then
        PYTEST_CMD="backend/.venv/bin/pytest"
    elif command -v pytest &> /dev/null; then
        PYTEST_CMD="pytest"
    else
        echo "⚠️  pytest not found. Skipping payment tests."
        PYTEST_CMD=""
    fi

    if [ -n "$PYTEST_CMD" ]; then
        export PYTHONPATH="$PYTHONPATH:$(pwd)"
        $PYTEST_CMD backend/tests/unit/test_payment_service.py::TestCreateCheckoutSession \
               -x --tb=short --no-cov -q 2>&1 | tail -5
        PYTEST_EXIT=${PIPESTATUS[0]}
        if [ "$PYTEST_EXIT" -ne 0 ]; then
            # Skip if failure is due to missing deps (ImportError/ModuleNotFoundError)
            if $PYTEST_CMD backend/tests/unit/test_payment_service.py::TestCreateCheckoutSession \
                   -x --tb=short --no-cov -q 2>&1 | grep -q "ModuleNotFoundError\|ImportError"; then
                echo "⚠️  Payment tests skipped (missing dependencies)"
            else
                echo "❌ Critical payment tests failed. DO NOT COMMIT."
                exit 1
            fi
        fi
    fi
fi

echo "✅ Pre-commit passed"
