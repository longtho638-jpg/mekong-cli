#!/bin/sh
# 🏯 PRE-PUSH HOOK - Binh Pháp CI Protection Layer 2
# Runs BEFORE code is pushed to remote

echo ""
echo "🚀 Pre-push: Validating before GitHub..."
echo "============================================"

# Check if we're pushing to main
BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" = "main" ]; then
    echo "   → Pushing to main - running full validation..."

    # Python tests (skip benchmarks that need LLM API)
    echo "   → Running Python tests..."
    python3 -m pytest tests/ -x -q --tb=line --ignore=tests/benchmarks 2>&1 | tail -10

    if [ $? -ne 0 ]; then
        echo ""
        echo "❌ Python tests failed - Push blocked!"
        echo "   Fix test errors before pushing to main."
        echo "============================================"
        exit 1
    fi

    echo ""
    echo "✅ Pre-push validation passed!"
    echo "   Safe to push to GitHub."
    echo "============================================"
else
    echo "   → Branch: $BRANCH (non-main, skipping full build)"
    echo "✅ Pre-push passed"
fi
