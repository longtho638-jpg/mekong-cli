{
  "id": "dealflow-term-sheet",
  "name": "Generate Term Sheet",
  "description": "Draft term sheet based on deal parameters, valuation, and investment thesis. 1 command, ~5 min.",
  "trigger": "/dealflow:term-sheet",
  "output_dir": "reports/dealflow/term-sheet",
  "estimated_credits": 3,
  "estimated_minutes": 5,
  "dag": {
    "groups": [
      {
        "id": "term-sheet",
        "name": "Draft Term Sheet",
        "mode": "sequential",
        "commands": [
          { "id": "dealflow-term-sheet", "args": "$ARGUMENTS" }
        ],
        "depends_on": []
      }
    ]
  }
}
